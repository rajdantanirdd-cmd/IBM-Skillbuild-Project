@app.route("/quiz")
def quiz():
    questions = load_quiz_questions()
    return render_template("quiz.html", question_count=len(questions))


@app.route("/api/quiz/questions")
def api_quiz_questions():
    questions = load_quiz_questions()
    safe_questions = [
        {
            "id": q["id"],
            "question": q["question"],
            "options": q["options"],
        }
        for q in questions
    ]
    return jsonify(safe_questions)


@app.route("/api/quiz/submit", methods=["POST"])
def api_quiz_submit():
    data = request.get_json()
    answers = data.get("answers", {})
    questions = load_quiz_questions()

    results = []
    score = 0

    for q in questions:
        qid = str(q["id"])
        user_answer = answers.get(qid)
        is_correct = user_answer == q["correct"]
        if is_correct:
            score += 1
        results.append(
            {
                "id": q["id"],
                "correct": is_correct,
                "correct_answer": q["correct"],
                "explanation": q["explanation"],
            }
        )

    total = len(questions)
    percentage = round((score / total) * 100) if total else 0

    if percentage >= 90:
        grade = "Expert"
        message = "Outstanding! You have excellent security awareness."
    elif percentage >= 70:
        grade = "Proficient"
        message = "Great job! Review the topics you missed to strengthen your knowledge."
    elif percentage >= 50:
        grade = "Developing"
        message = "Good start! We recommend completing the training modules."
    else:
        grade = "Beginner"
        message = "Keep learning! Explore our training modules and threat guides."

    return jsonify(
        {
            "score": score,
            "total": total,
            "percentage": percentage,
            "grade": grade,
            "message": message,
            "results": results,
        }
    )


